# Supabase — get from project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

# Supabase Edge Function secrets (set via: supabase secrets set KEY=value)
# ANTHROPIC_API_KEY=sk-ant-...
# RESEND_API_KEY=re_...
# SUPABASE_AUTH_HOOK_SECRET=...   (from Supabase Auth → Hooks settings)

# Stripe (Edge Function secrets)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_ID=price_...       (Monthly Pro price ID from Stripe Dashboard)
# STRIPE_WEBHOOK_SECRET=whsec_... (from Stripe Dashboard → Webhooks)
